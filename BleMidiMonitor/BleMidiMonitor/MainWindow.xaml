<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="BleMidiMonitor.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BleMidiMonitor"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="BleMidiMonitor">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="BLE MIDI Monitor"
                   FontSize="28"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="10" Margin="0,0,0,10">
            <Button x:Name="ScanButton"
                    Content="Scan for Devices"
                    Click="ScanButton_Click"
                    Padding="20,10"/>
            <Button x:Name="StopScanButton"
                    Content="Stop Scan"
                    Click="StopScanButton_Click"
                    Padding="20,10"
                    IsEnabled="False"/>
            <Button x:Name="DisconnectButton"
                    Content="Disconnect"
                    Click="DisconnectButton_Click"
                    Padding="20,10"
                    IsEnabled="False"/>
            <Button x:Name="ShowFretboardButton"
                    Content="AeroBand Fret"
                    Click="ShowFretboardButton_Click"
                    Padding="20,10"/>
        </StackPanel>

        <TextBlock Grid.Row="2"
                   x:Name="StatusText"
                   Text="Click the button to scan for devices"
                   FontStyle="Italic"
                   Foreground="Gray"
                   Margin="0,0,0,10"/>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Device List -->
            <Grid Grid.Column="0" Margin="0,0,10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Devices"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Margin="0,0,0,10"/>

                <ListView Grid.Row="1"
                          x:Name="DeviceListView"
                          SelectionMode="Single"
                          IsItemClickEnabled="True"
                          ItemClick="DeviceListView_ItemClick">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="10,8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="{Binding Name}"
                                           FontSize="14"
                                           FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="1"
                                           Text="{Binding AddressString}"
                                           FontSize="11"
                                           Foreground="Gray"/>
                                <TextBlock Grid.Row="2"
                                           Text="{Binding StatusText}"
                                           FontSize="11"
                                           Foreground="Gray"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <!-- Right Panel: MIDI Log -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="MIDI Messages"
                               FontSize="18"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="MessageCountText"
                               Text="Messages: 0"
                               FontSize="14"
                               Foreground="Gray"
                               Margin="15,0,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <ListView Grid.Row="1"
                          x:Name="MidiLogListView"
                          SelectionMode="None"
                          IsItemClickEnabled="False"
                          FontFamily="Consolas">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}"
                                       FontSize="12"
                                       TextWrapping="NoWrap"/>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <Button Grid.Row="2"
                        x:Name="ClearLogButton"
                        Content="Clear Log"
                        Click="ClearLogButton_Click"
                        HorizontalAlignment="Right"
                        Margin="0,10,0,0"
                        Padding="15,8"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
